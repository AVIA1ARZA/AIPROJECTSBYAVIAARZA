rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // חוקי הגנה עבור השאילתות שהושלמו
    match /completed_questions/{documentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // פתרון רווחים: תפיסת שם הקולקשן כמשתנה ובדיקה אם הוא שווה ל-saved tips
    match /{collectionName}/{documentId} {
      allow read: if collectionName == "saved tips";
      allow write: if collectionName == "saved tips" && request.auth != null;
    }

    // חוקי הגנה עבור פרופילי המשתמשים
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
